<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A12">

    <!-- ═══════════ CARTE PRINCIPALE ═══════════ -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ═══════════ BANDEAU STATS EN HAUT ═══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#D9000010"
        android:elevation="6dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="10dp"
        android:paddingEnd="8dp"
        android:paddingBottom="10dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tvDistance" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0.00 km"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="distance" android:textColor="#88AACCFF" android:textSize="10sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="36dp"
            android:layout_gravity="center_vertical" android:background="#33FFFFFF"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tvDuration" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="00:00:00"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="durée" android:textColor="#88AACCFF" android:textSize="10sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="36dp"
            android:layout_gravity="center_vertical" android:background="#33FFFFFF"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tvAvgSpeed" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0.0 km/h"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="moy." android:textColor="#88AACCFF" android:textSize="10sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="36dp"
            android:layout_gravity="center_vertical" android:background="#33FFFFFF"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tvCalories" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0 kcal"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="calories" android:textColor="#88AACCFF" android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════ BOUTON TÉLÉCHARGER ZONE + STATUT (côté droit, milieu) ═══════════ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/btnDownloadZone"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/music_panel_bg"
            android:contentDescription="Télécharger la zone"
            android:padding="10dp"
            android:src="@android:drawable/stat_sys_download" />

        <TextView
            android:id="@+id/tvDownloadStatus"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/music_panel_bg"
            android:gravity="center"
            android:padding="6dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ═══════════ PANNEAU MUSIQUE (bas gauche) ═══════════ -->
    <LinearLayout
        android:layout_width="190dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="14dp"
        android:background="@drawable/music_panel_bg"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/tvSongInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="marquee"
            android:maxLines="1"
            android:text="🎵 Aucune musique"
            android:textColor="#DDDDFF"
            android:textSize="11sp" />

        <com.veloapp.MusicVisualizerView
            android:id="@+id/musicVisualizer"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- ═══════════ CERCLE VITESSE (bas droite) ═══════════ -->
    <FrameLayout
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="14dp"
        android:background="@drawable/speed_circle_bg"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="38sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="km/h"
                android:textColor="#88AACCFF"
                android:textSize="11sp" />

        </LinearLayout>
    </FrameLayout>

</FrameLayout>
